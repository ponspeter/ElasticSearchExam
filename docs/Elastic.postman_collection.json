    {
      "name": "Electronics Price Range & Brand Filter",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"query\": {\r\n    \"bool\": {\r\n      \"filter\": [\r\n        { \"term\": { \"category\": \"Electronics\" } },\r\n        { \"range\": { \"price\": { \"gte\": 50, \"lte\": 800 } } },\r\n        { \"term\": { \"in_stock\": true } }\r\n      ],\r\n      \"should\": [\r\n        { \"term\": { \"brand\": \"Sony\" } },\r\n        { \"term\": { \"brand\": \"Samsung\" } }\r\n      ],\r\n      \"minimum_should_match\": 1\r\n    }\r\n  }\r\n}",
